VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=campaign-hub-b33c6.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Optional: direct AI service URL (local dev with ai-service on :8000)
VITE_AI_SERVICE_URL=

# Vercel serverless (set in Vercel project env, not in frontend .env):
# GEMINI_API_KEY=   — presentation & upload content
# OPENAI_API_KEY=   — dashboard chat & recommendations
# AI_SERVICE_URL=   — optional proxy to Python ai-service
