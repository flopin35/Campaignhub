rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isVerifiedUser() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isImage() {
      return request.resource != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp)');
    }

    // Campaign assets — public read, verified users only write
    match /campaigns/{allPaths=**} {
      allow read: if true;
      allow write: if isVerifiedUser() && isImage();
    }

    match /payments/screenshots/{fileName} {
      allow read: if request.auth != null;
      allow write: if isVerifiedUser() && isImage();
    }

    match /payments/proofs/{fileName} {
      allow read: if request.auth != null;
      allow write: if isVerifiedUser() && isImage();
    }

    match /users/avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if isVerifiedUser()
        && request.auth.uid == userId
        && isImage();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
